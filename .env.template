# MongoDB 配置
# ------------------------------------------
MONGO_INITDB_ROOT_USERNAME=scienceone
MONGO_INITDB_ROOT_PASSWORD=change_this_password

# ------------------------------------------
# WebSearch 配置
# ------------------------------------------
WEBSEARCH_API_KEY=change_this_api_key

# ------------------------------------------
# 后台管理员账户
