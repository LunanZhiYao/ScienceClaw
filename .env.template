FRONTEND_ENDPOINT=http://localhost:5173

# ------------------------------------------
# 任务服务 API Key
# ------------------------------------------
TASK_SERVICE_API_KEY=

# ------------------------------------------
# DeepSeek / LLM 配置
# ------------------------------------------
DS_API_KEY=
DS_URL=https://api.deepseek.com/v1
DS_MODEL=deepseek-chat
TEMPERATURE=0.7
MAX_TOKENS=2000

# ------------------------------------------
