BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change_this_admin_password
BOOTSTRAP_ADMIN_FULLNAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@localhost

# ------------------------------------------
# ERP 配置
